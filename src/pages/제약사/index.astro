---
import Layout from '../../layouts/Layout.astro';
import { prefetchAll } from '../../lib/mfds';
import { slugify } from '../../lib/slugify';

const { drugs } = await prefetchAll();
const map = new Map<string, number>();
for (const d of drugs) {
  if (d.entpName) map.set(d.entpName, (map.get(d.entpName) ?? 0) + 1);
}
const sorted = Array.from(map.entries()).filter(([, n]) => n >= 2).sort((a, b) => b[1] - a[1]);
---
<Layout title="제약사별 의약품" description={`${sorted.length}개 제약사`}>
  <h2>제약사별 의약품</h2>
  <p>총 <strong>{sorted.length}</strong>개 제약사</p>
  <div class="entp-grid">
    {sorted.map(([e, n]) => (
      <a href={`/제약사/${slugify(e)}`} class="entp-card">
        <span class="entp-name">{e}</span>
        <span class="entp-count">{n}</span>
      </a>
    ))}
  </div>
</Layout>

<style>
  .entp-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 6px; margin-top: 16px;
  }
  .entp-card {
    display: flex; justify-content: space-between; align-items: center;
    padding: 10px 14px; background: #fff; border: 1px solid #ddd; border-radius: 6px;
    text-decoration: none; color: #222; font-size: 14px;
  }
  .entp-card:hover { background: #f5f9ff; border-color: #2563eb; }
  .entp-count { color: #2563eb; font-weight: 600; font-size: 13px; }
</style>
