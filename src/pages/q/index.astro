---
import Layout from '../../layouts/Layout.astro';
import { QAS } from '../../lib/qa-seed';

const categories = Array.from(new Set(QAS.map((q) => q.category)));
---
<Layout title="자주 묻는 질문 (Q&A)" description={`의약품 복용·보관·안전성 등 자주 묻는 ${QAS.length}개 질문에 대한 답`}>
  <h2>의약품 자주 묻는 질문</h2>
  <p>약사가 자주 받는 질문을 정리했습니다. 총 <strong>{QAS.length}개</strong> 질문.</p>

  {categories.map((cat) => {
    const items = QAS.filter((q) => q.category === cat);
    return (
      <section>
        <h3>{cat}</h3>
        <ul class="qa-list">
          {items.map((q) => (
            <li>
              <a href={`/q/${q.slug}`}>{q.q}</a>
            </li>
          ))}
        </ul>
      </section>
    );
  })}
</Layout>

<style>
  .qa-list { list-style: none; padding: 0; margin: 8px 0; }
  .qa-list li {
    padding: 12px 16px; background: #fff; border: 1px solid var(--border);
    border-radius: 6px; margin-bottom: 4px; transition: all 0.15s;
  }
  .qa-list li:hover { border-color: var(--navy-800); transform: translateX(2px); }
  .qa-list a { color: var(--navy-900); font-weight: 500; font-size: 15px; }
</style>
