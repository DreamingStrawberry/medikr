---
import Layout from '../layouts/Layout.astro';
import AdSlot from '../components/AdSlot.astro';
import FreshBadge from '../components/FreshBadge.astro';
import TrustBox from '../components/TrustBox.astro';
import { fetchAllCosmetics, fetchAllFunctionalCosmetics } from '../lib/mfds';

const [cosmetics, functional] = await Promise.all([
  fetchAllCosmetics().catch(() => []),
  fetchAllFunctionalCosmetics().catch(() => []),
]);
const total = cosmetics.length + functional.length;
---
<Layout
  title="화장품 정보"
  description={`식약처 공식 화장품 데이터 ${total.toLocaleString()}건 — 기능성 화장품·원료성분·규제정보`}
>
  <nav class="crumb" aria-label="breadcrumb">
    <a href="/">홈</a> <span>›</span> <span class="cur">화장품</span>
  </nav>

  <FreshBadge compact />
  <h2>화장품 정보</h2>
  <p class="meta">식약처 공식 화장품 데이터 — 기능성화장품 보고품목, 원료성분.</p>

  <AdSlot slot="9000000001" format="auto" />

  {total > 0 ? (
    <section>
      <h3>등록 화장품 ({total.toLocaleString()}건)</h3>
      <ul class="prod-list">
        {[...cosmetics, ...functional].slice(0, 100).map((p) => (
          <li>
            <strong>{p.PRDT_NM || p.ITEM_NAME || p.PRODUCT_NAME || '제품명 미상'}</strong>
            {(p.ENTP_NAME || p.MNF_NM) && <span class="entp"> — {p.ENTP_NAME || p.MNF_NM}</span>}
          </li>
        ))}
      </ul>
      {total > 100 && <p class="more">총 {total.toLocaleString()}건 중 100건 표시</p>}
    </section>
  ) : (
    <section class="coming">
      <h3>데이터 활성화 대기 중</h3>
      <p>식약처 화장품 OpenAPI 활용신청 + 정확한 endpoint 등록 후 다음 빌드부터 자동 노출됩니다.</p>
      <ul>
        <li>화장품 관련 정보 (data.go.kr/data/15020628)</li>
        <li>기능성화장품 보고품목 (15095680)</li>
        <li>화장품 원료성분정보 (15111774)</li>
      </ul>
    </section>
  )}

  <TrustBox />
</Layout>

<style>
  .crumb { font-size: 13px; color: var(--text-muted); margin-bottom: 12px; display: flex; gap: 6px; }
  .crumb a { color: var(--text-muted); }
  .crumb .cur { color: var(--navy-900); font-weight: 600; }
  .meta { color: var(--text-muted); margin-bottom: 16px; }
  .coming { background: var(--bg-muted); border-left: 3px solid var(--navy-900); padding: 20px 24px; border-radius: 8px; }
  .coming h3 { margin-top: 0; }
  .coming ul { padding-left: 22px; margin: 12px 0; }
  .prod-list { list-style: none; padding: 0; }
  .prod-list li { padding: 10px 14px; background: #fff; border: 1px solid var(--border); border-radius: 6px; margin-bottom: 4px; }
  .prod-list .entp { color: var(--text-muted); font-size: 13px; }
  .more { color: var(--text-muted); font-size: 13px; text-align: center; padding: 8px; }
</style>
